VITE_API_BASE_URL=https://api.mediarosenqvist.com

# Supabase (Lovable Cloud) — auth + database
VITE_SUPABASE_URL=https://<your-project>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-publishable-or-anon-key>

# Backend (music-catalog-core) auth + API key hardening
# These are consumed by the backend service, not this frontend bundle.
JWT_SECRET=
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=
REFRESH_TOKEN_EXPIRES_IN=7d
API_KEY_SECRET=
CORS_ORIGINS=https://catalogusmusicus.mediarosenqvist.com,http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=10
